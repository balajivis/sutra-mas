# Sutra Environment Configuration
# Copy to .env and fill in your values

# ─────────────────────────────────────────────
# Database (Neon Postgres or local)
# ─────────────────────────────────────────────
SUTRA_DB_URL=postgresql://user:password@host/sutra?sslmode=require

# ─────────────────────────────────────────────
# LLM Providers (for pipeline + experiments)
# ─────────────────────────────────────────────

# Azure OpenAI (used by pipeline agents 2, 3b, 8)
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_CHAT_MODEL=gpt-4o          # or gpt-4.1, gpt-5.1

# Azure Anthropic (used by experiments)
AZURE_ANTHROPIC_ENDPOINT=https://your-resource.services.ai.azure.com/openai/deployments/claude-opus-4-6
AZURE_ANTHROPIC_MODEL=claude-opus-4-6
AZURE_API_KEY=your-key-here

# Direct Anthropic API (alternative to Azure)
# ANTHROPIC_API_KEY=your-key-here

# Direct OpenAI API (alternative to Azure)
# OPENAI_API_KEY=your-key-here

# ─────────────────────────────────────────────
# External APIs (for pipeline collection)
# ─────────────────────────────────────────────

# OpenAlex (free, 100K requests/day with polite pool)
OPENALEX_API_KEY=your-key-here
# Or use mailto for polite pool (no key needed):
# OPENALEX_MAILTO=your-email@example.com

# ─────────────────────────────────────────────
# Dashboard (Next.js)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/sutra?sslmode=require
