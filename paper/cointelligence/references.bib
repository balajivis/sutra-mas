@article{li2026humanai,
  title={Human-AI Synergy Supports Collective Creative Search},
  author={Li, Chenyi and Marjieh, Raja and Hu, Haoyu and Steyvers, Mark and Collins, Katherine M. and Sucholutsky, Ilia and Jacoby, Nori},
  journal={arXiv preprint arXiv:2602.10001},
  year={2026},
  note={STRONGEST EMPIRICAL EVIDENCE for cointelligence (Thread 12). Cornell/Princeton/MIT/UCI/NYU. 131 humans + Gemini 2.5 Flash + GPT 5.1. Semantic search task. Hybrid outperforms AI-only by 26\% (119.77 vs 94.80). AI-only has LOWEST diversity (d=2.22 vs human). THE KILLER FINDING: heterogeneous AI (Gemini+GPT) gives non-significant improvement (p=.21). Human+AI gives highly significant improvement (p<.001). More AI $\neq$ better. Different cognition = better. Both agents ADAPT in hybrid: AI performance improves (p<.001, d=0.34), human lexical diversity increases (p<.001). AI-only shows no strategy adaptation (r=0.12). Hybrid shows adaptive exploration$\to$exploitation (r significant negative). Limitation: word-guessing task, not research. But cognitive dynamics generalize. Supports Threads 2, 5, 7, 9.}
}

