@article{skarlinski2024paperqa2,
  title={Language Agents Achieve Superhuman Synthesis of Scientific Knowledge},
  author={Skarlinski, Michael D. and Cox, Sam and Laurent, Jon M. and Braza, James D. and Hinks, Michaela and Ponnapati, Manvitha and Rodriques, Samuel G. and White, Andrew D.},
  journal={arXiv preprint arXiv:2409.13740},
  year={2024},
  note={THE STRONGEST AUTONOMY-CAMP CLAIM — and it dissolves on inspection (Thread 11). 93 citations. NOT peer-reviewed (17 months on arXiv). ``Superhuman'' applies to PRECISION only (85.2\% vs 64-74\% human, p=0.003). ACCURACY is NOT superhuman (66\% vs 63-68\%, p=0.63). System achieves precision by abstaining 22\% of the time. LitQA2 benchmark: 248 MC questions, each answerable from SINGLE paper = retrieval, not synthesis. Self-designed benchmark, 9 humans, biology only. Performance ``drops significantly'' without MC options (model uses answer keywords as search terms). WikiCrow gene articles: fewer unsupported citations than Wikipedia but domain errors (outdated coordinates, missing gene relationships). ContraCrow contradiction detection: 70\% validated, 30\% false positives. OpenScholar (Nature 2026) outperforms by 5-7\% on independent benchmark at 333x lower cost. Foundation for Robin's Crow/Falcon agents. Open source (7,000+ stars). Supports Thread 11: superhuman at retrieval (easy), not at synthesis (hard).}
}

